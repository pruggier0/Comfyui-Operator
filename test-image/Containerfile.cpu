FROM docker.io/python:3.12-slim

ENV DEBIAN_FRONTEND=noninteractive

WORKDIR /app

# Install git, wget, nano, and curl
RUN apt-get update && \
    apt-get install -y git wget nano curl && \
    apt-get clean && \
    rm -rf /var/lib/apt/lists/*

# Install filebrowser for web-based file management
RUN curl -fsSL https://raw.githubusercontent.com/filebrowser/get/master/get.sh | bash

# Clone ComfyUI
RUN git clone https://github.com/comfyanonymous/ComfyUI.git /app/ComfyUI

WORKDIR /app/ComfyUI

# Install PyTorch CPU-only version (NO CUDA)
RUN pip install --no-cache-dir torch torchvision torchaudio --index-url https://download.pytorch.org/whl/cpu && \
    pip install --no-cache-dir -r requirements.txt

# Install ComfyUI Manager dependencies (built-in manager)
RUN pip install --no-cache-dir -r manager_requirements.txt

# Clone standalone ComfyUI-Manager into custom_nodes for legacy UI
RUN git clone https://github.com/ltdrdata/ComfyUI-Manager.git /app/ComfyUI/custom_nodes/ComfyUI-Manager && \
    pip install --no-cache-dir -r /app/ComfyUI/custom_nodes/ComfyUI-Manager/requirements.txt

# Create a non-root user for OpenShift compatibility
RUN useradd -m -u 1000 -s /bin/bash comfyui && \
    chown -R 1000:1000 /app

# Set required environment variables
ENV USER=comfyui
ENV HOME=/app

# Create entrypoint script to set up directories and install custom node dependencies
RUN echo '#!/bin/bash\n\
set -e\n\
echo "=== Setting up ComfyUI persistent storage ==="\n\
\n\
# Create all required model subdirectories\n\
mkdir -p /app/ComfyUI/models/checkpoints \\\n\
         /app/ComfyUI/models/vae \\\n\
         /app/ComfyUI/models/loras \\\n\
         /app/ComfyUI/models/embeddings \\\n\
         /app/ComfyUI/models/controlnet \\\n\
         /app/ComfyUI/models/clip \\\n\
         /app/ComfyUI/models/clip_vision \\\n\
         /app/ComfyUI/models/text_encoders \\\n\
         /app/ComfyUI/models/diffusion_models \\\n\
         /app/ComfyUI/models/unet \\\n\
         /app/ComfyUI/models/upscale_models \\\n\
         /app/ComfyUI/models/hypernetworks \\\n\
         /app/ComfyUI/models/style_models\n\
\n\
# Create other required directories\n\
mkdir -p /app/ComfyUI/user \\\n\
         /app/ComfyUI/output \\\n\
         /app/ComfyUI/input \\\n\
         /app/ComfyUI/temp \\\n\
         /app/ComfyUI/custom_nodes \n\
\n\
echo "✓ Directory structure created"\n\
\n\
# Clone ComfyUI-Manager if not already present (for legacy UI)\n\
if [ ! -d "/app/ComfyUI/custom_nodes/ComfyUI-Manager" ]; then\n\
  echo "=== Installing ComfyUI-Manager ==="\n\
  git clone https://github.com/ltdrdata/ComfyUI-Manager.git /app/ComfyUI/custom_nodes/ComfyUI-Manager\n\
  pip install --no-cache-dir -r /app/ComfyUI/custom_nodes/ComfyUI-Manager/requirements.txt\n\
  echo "✓ ComfyUI-Manager installed"\n\
else\n\
  echo "✓ ComfyUI-Manager already exists"\n\
fi\n\
\n\
# Install dependencies for custom nodes\n\
echo "=== Installing custom node dependencies ==="\n\
custom_nodes_with_deps=0\n\
for node_dir in /app/ComfyUI/custom_nodes/*; do\n\
  # Skip if not a directory or if it'\''s the ComfyUI-Manager\n\
  if [ ! -d "$node_dir" ]; then\n\
    continue\n\
  fi\n\
  \n\
  node_name=$(basename "$node_dir")\n\
  \n\
  # Check for requirements.txt\n\
  if [ -f "$node_dir/requirements.txt" ]; then\n\
    echo "→ Installing dependencies for: $node_name"\n\
    pip install --no-cache-dir -r "$node_dir/requirements.txt" || {\n\
      echo "⚠ Warning: Failed to install dependencies for $node_name" >&2\n\
      echo "   ComfyUI will start but this custom node may not work" >&2\n\
    }\n\
    custom_nodes_with_deps=$((custom_nodes_with_deps + 1))\n\
  fi\n\
  \n\
  # Check for install.py (some custom nodes use this)\n\
  if [ -f "$node_dir/install.py" ]; then\n\
    echo "→ Running install script for: $node_name"\n\
    (cd "$node_dir" && python install.py) || {\n\
      echo "⚠ Warning: install.py failed for $node_name" >&2\n\
    }\n\
  fi\n\
done\n\
\n\
if [ $custom_nodes_with_deps -eq 0 ]; then\n\
  echo "✓ No custom node dependencies to install"\n\
else\n\
  echo "✓ Installed dependencies for $custom_nodes_with_deps custom node(s)"\n\
fi\n\
\n\
# Start ComfyUI with Manager enabled\n\
echo "=== Starting File Browser ==="\n\
filebrowser config init --port 8080 --address 0.0.0.0 --root /app/ComfyUI --database /app/ComfyUI/filebrowser.db\n\
filebrowser config set --auth.method=noauth --database /app/ComfyUI/filebrowser.db\n\
filebrowser --database /app/ComfyUI/filebrowser.db > /tmp/filebrowser.log 2>&1 &\n\
sleep 2\n\
\n\
echo "=== Starting ComfyUI (CPU-only mode) ==="\n\
exec python main.py --listen 0.0.0.0 --port 8188 --cpu\n\
' > /app/entrypoint.sh && \
    chmod +x /app/entrypoint.sh

# Switch to non-root user
USER 1000

# Expose the default ComfyUI port
EXPOSE 8188

# Run entrypoint script
ENTRYPOINT ["/app/entrypoint.sh"]
